# Firebase (Client SDK)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Gemini (Server)
GOOGLE_GEMINI_API_KEY=

# Anthropic Claude (Server) - for video frame analysis
ANTHROPIC_API_KEY=

# Cloudinary (Client upload)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
# Optional: set > 0 to enforce client-side upload cap (MB). Leave empty to rely on Cloudinary limits.
NEXT_PUBLIC_CLOUDINARY_MAX_FILE_SIZE_MB=
# Optional: chunk size (MB) for Cloudinary chunked upload. Default 5.
NEXT_PUBLIC_CLOUDINARY_CHUNK_SIZE_MB=5
# Optional: per-request timeout in milliseconds. Default 45000.
NEXT_PUBLIC_CLOUDINARY_REQUEST_TIMEOUT_MS=45000
# Optional: retry count per request/chunk (0 = no retry). Default 2.
NEXT_PUBLIC_CLOUDINARY_CHUNK_RETRY=2

# Optional: comma-separated extra admin IDs (defaults already include PH_admin,GV_admin)
NEXT_PUBLIC_ADMIN_USER_IDS=
